# Required for the default model in this template.
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# Optional: override the default model string used by src/simple_agent/graph.py.
SIMPLE_AGENT_MODEL=anthropic:claude-sonnet-4-6

# Optional but recommended for tracing.
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=simple-agent
LANGSMITH_DEPLOYMENT_NAME='simple-agent'

# Other optional keys for additional models, evaluation, and tracing.
TAVILY_API_KEY=tvly-...